FROM python:3.10-bullseye

WORKDIR /code

RUN apt-get update \
    && apt-get install netcat ffmpeg libsm6 libxext6 -y

COPY ./requirements.txt /code/requirements.txt

RUN pip install --no-cache-dir --root-user-action=ignore  --upgrade -r requirements.txt

COPY . .

CMD gunicorn app.main:app --workers 1 --worker-class uvicorn.workers.UvicornWorker --bind=0.0.0.0:80
